# ════════════════════════════════════════════════════
# Farmer Behavioral Twin — .gitignore
# ════════════════════════════════════════════════════

# ── NEVER commit these ───────────────────────────────
.env
*.env
.env.*
!.env.example

# ── Database ─────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
farmer_twin.db

# ── Audio files generated by gTTS ────────────────────
*.mp3
nudge_audio.mp3

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual Environments ─────────────────────────────
venv/
env/
ENV/
.venv/
.env/
myenv/

# ── Streamlit ────────────────────────────────────────
.streamlit/secrets.toml

# ── OS Files ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────
*.log
logs/

# ── Jupyter ──────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/